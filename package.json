{
  "name": "sve-tools",
  "version": "2.4.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check lint format \"build-only {@}\" --",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json --composite false",
    "lint": "oxlint",
    "format": "oxfmt",
    "release": "standard-version"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "@tsconfig/node20": "^20.1.9",
    "@types/lodash-es": "^4.17.12",
    "@unhead/vue": "^3.0.4",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "date-fns": "^4.1.0",
    "lodash-es": "^4.18.1",
    "npm-run-all": "^4.1.5",
    "pinia": "^3.0.4",
    "typescript": "^6.0.3",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.8",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vue-tsc": "^3.2.6",
    "vuetify": "4.0.5"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.16.1",
    "@types/node": "^25.6.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "standard-version": "^9.5.0"
  }
}
